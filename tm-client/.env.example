# Market CSGO API Client Configuration

# Required: Your Market CSGO API key
# Get this from https://market.csgo.com/api
MARKET_CSGO_API_KEY=your_api_key_here

# Optional: API version to use (v1 or v2)
# Default: v2
MARKET_API_VERSION=v2

# Runtime
NODE_ENV=dev
LOG_LEVEL=info
BASE_URL=https://market.csgo.com/api
VERSION=v2
API_KEY=your_api_key_here
REQUEST_TIMEOUT_MS=30000
MAX_RETRIES=3
RETRY_DELAY_MS=1000
RETRY_BACKOFF_MULTIPLIER=2
MAX_BACKOFF_MS=10000
REQUESTS_PER_SECOND=5
PING_INTERVAL_MS=180000
MARKET_TRADE_POLL_INTERVAL_MS=15000
MARKET_TRADE_EMPTY_POLL_INTERVAL_MS=30000
MARKET_TRADE_OFFER_TTL_MS=300000
MARKET_ITEMS_POLL_INTERVAL_MS=300000

# Queue
AZURE_QUEUE_CONNECTION_STRING=
AZURE_QUEUE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_NAME=storageaccountname
AZURE_QUEUE_CREATE_IF_NOT_EXISTS=false
BOT_INCOMING_TRADE_QUEUE_NAME=incoming-trades
BOT_TRADE_STATUS_QUEUE_NAME=trade-status
PLATFORM_TRADE_READY_QUEUE_NAME=platform-trade-ready
BOT_QUEUE_VISIBILITY_TIMEOUT_SECONDS=60
BOT_QUEUE_MAX_MESSAGES=4
BOT_QUEUE_MAX_DEQUEUE_COUNT=5

# Storage
ACCOUNT_NAME=tm-client
AZURE_BLOB_CONTAINER_NAME=steam-bot
AZURE_TABLE_CONNECTION_STRING=
AZURE_TRADE_TABLE_NAME=Trades
AZURE_MARKET_ITEMS_TABLE_NAME=MarketItems
AZURE_TABLE_PARTITION_KEY=tm-client
AZURE_TABLE_CREATE_IF_NOT_EXISTS=false
