{
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": ["admin"]
    },
    {
      "route": "/*",
      "allowedRoles": ["admin"]
    }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad",
      "statusCode": 302
    }
  },
  "navigationFallback": {
    "rewrite": "/index.html"
  }
}