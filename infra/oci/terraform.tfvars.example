tenancy_ocid     = "ocid1.tenancy.oc1..replace-me"
user_ocid        = "ocid1.user.oc1..replace-me"
fingerprint      = "replace-me"
private_key_path = "~/.oci/oci_api_key.pem"
region           = "eu-frankfurt-1"
compartment_ocid = "ocid1.compartment.oc1..replace-me"

project_name     = "cs-tm-bot"
environment_name = "dev"

ssh_public_key   = "ssh-ed25519 replace-me"
ssh_allowed_cidr = "0.0.0.0/0"

# Current Oracle Always Free full-month Ampere A1 allowance is 2 OCPUs and 12 GB RAM.
availability_domain_index = 1
instance_ocpus      = 2
instance_memory_gbs = 12

node_major_version = 22
app_root           = "/opt/market-bot/app"

steam_bot_env = {
  BOT_ENV                                = "dev"
  LOG_LEVEL                              = "info"
  STEAM_ACCOUNT_NAME                     = "replace-me"
  STEAM_PASSWORD                         = "replace-me"
  STEAM_SHARED_SECRET                    = "replace-me"
  STEAM_IDENTITY_SECRET                  = "replace-me"
  STEAM_GUARD_CODE                       = ""
  STEAM_API_DOMAIN                       = "localhost"
  STEAM_TOKEN_PLATFORM                   = "mobile"
  BOT_INVENTORY_POLL_INTERVAL_MS         = "43200000"
  BOT_POLL_INTERVAL_MS                   = "30000"
  BOT_CANCEL_TIME_MS                     = "600000"
  BOT_LOGIN_TIMEOUT_MS                   = "90000"
  BOT_MAX_LOGIN_RETRIES                  = "3"
  BOT_LOGIN_RETRY_DELAY_MS               = "5000"
  BOT_MAX_LOGIN_ATTEMPTS_WITHIN_PERIOD   = "3"
  BOT_LOGIN_ATTEMPT_PERIOD_MS            = "60000"
  BOT_OFFER_REQUEST_TTL_MS               = "300000"
  BOT_OFFER_MAX_RETRIES                  = "4"
  BOT_OFFER_RETRY_BASE_DELAY_MS          = "5000"
  BOT_OFFER_RETRY_MAX_DELAY_MS           = "30000"
  BOT_TOKEN_REFRESH_INTERVAL_MS          = "300000"
  BOT_TOKEN_REFRESH_SKEW_MS              = "120000"
  BOT_ACCESS_TOKEN_REFRESH_SKEW_MS       = "14400000"
  BOT_REFRESH_TOKEN_RENEWAL_WINDOW_MS    = "604800000"
  BOT_QUEUE_ENABLED                      = "true"
  BOT_INCOMING_TRADE_QUEUE_NAME          = "trade-requests"
  BOT_TRADE_STATUS_QUEUE_NAME            = "trade-status-update"
  AZURE_QUEUE_CONNECTION_STRING          = "replace-me"
  AZURE_QUEUE_CREATE_IF_NOT_EXISTS       = "true"
  BOT_QUEUE_VISIBILITY_TIMEOUT_SECONDS   = "60"
  BOT_QUEUE_MAX_MESSAGES                 = "1"
  BOT_QUEUE_MAX_DEQUEUE_COUNT            = "5"
}

tm_client_env = {
  NODE_ENV                                = "dev"
  LOG_LEVEL                               = "info"
  BASE_URL                                = "https://market.csgo.com/api"
  VERSION                                 = "v2"
  API_KEY                                 = "replace-me"
  REQUEST_TIMEOUT_MS                      = "30000"
  MAX_RETRIES                             = "3"
  RETRY_DELAY_MS                          = "1000"
  RETRY_BACKOFF_MULTIPLIER                = "2"
  MAX_BACKOFF_MS                          = "10000"
  REQUESTS_PER_SECOND                     = "5"
  PING_INTERVAL_MS                        = "180000"
  MARKET_TRADE_POLL_INTERVAL_MS           = "15000"
  MARKET_TRADE_EMPTY_POLL_INTERVAL_MS     = "30000"
  MARKET_TRADE_OFFER_TTL_MS               = "300000"
  MARKET_ITEMS_POLL_INTERVAL_MS           = "300000"
  MARKET_ITEMS_EMPTY_POLL_INTERVAL_MS     = "1800000"
  BOT_INCOMING_TRADE_QUEUE_NAME           = "trade-requests"
  BOT_TRADE_STATUS_QUEUE_NAME             = "trade-status-update"
  PLATFORM_TRADE_READY_QUEUE_NAME         = "platform-trade-ready"
  AZURE_QUEUE_CONNECTION_STRING           = "replace-me"
  AZURE_QUEUE_CREATE_IF_NOT_EXISTS        = "true"
  BOT_QUEUE_VISIBILITY_TIMEOUT_SECONDS    = "60"
  BOT_QUEUE_MAX_MESSAGES                  = "4"
  BOT_QUEUE_MAX_DEQUEUE_COUNT             = "5"
  ACCOUNT_NAME                            = "default"
  AZURE_STORAGE_ACCOUNT_NAME              = "replace-me"
  AZURE_BLOB_CONTAINER_NAME               = "bot-state"
  AZURE_TABLE_CONNECTION_STRING           = "replace-me"
  AZURE_TRADE_TABLE_NAME                  = "Trades"
  AZURE_MARKET_ITEMS_TABLE_NAME           = "MarketItems"
  AZURE_TABLE_PARTITION_KEY               = "default"
  AZURE_TABLE_CREATE_IF_NOT_EXISTS        = "true"
}
