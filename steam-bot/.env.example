# Bot runtime
BOT_ENV=dev
LOG_LEVEL=info
STEAM_ACCOUNT_NAME=your-login
STEAM_PASSWORD=password
STEAM_SHARED_SECRET=secret
STEAM_IDENTITY_SECRET=identity-secret
STEAM_GUARD_CODE=
STEAM_API_DOMAIN=localhost
STEAM_TOKEN_PLATFORM=mobile

# Bot timings and retry policy
BOT_POLL_INTERVAL_MS=30000
BOT_CANCEL_TIME_MS=600000
BOT_LOGIN_TIMEOUT_MS=90000
BOT_MAX_LOGIN_RETRIES=3
BOT_LOGIN_RETRY_DELAY_MS=5000
BOT_MAX_LOGIN_ATTEMPTS_WITHIN_PERIOD=3
BOT_LOGIN_ATTEMPT_PERIOD_MS=60000
BOT_OFFER_REQUEST_TTL_MS=300000
BOT_OFFER_MAX_RETRIES=4
BOT_OFFER_RETRY_BASE_DELAY_MS=5000
BOT_OFFER_RETRY_MAX_DELAY_MS=30000
BOT_TOKEN_REFRESH_INTERVAL_MS=300000
BOT_TOKEN_REFRESH_SKEW_MS=120000
BOT_ACCESS_TOKEN_REFRESH_SKEW_MS=14400000
BOT_REFRESH_TOKEN_RENEWAL_WINDOW_MS=604800000

# Storage
BOT_STORAGE_DRIVER=azure
BOT_LOCAL_DATA_DIR=.steam-bot-data
AZURE_BOT_CONTAINER_NAME=steam-bot
BOT_INVENTORY_POLL_INTERVAL_MS=43200000
# AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT_NAME=storageaccountname
KEY_VAULT_URL=https://key-vault.vault.azure.net

# Queue
BOT_QUEUE_ENABLED=true
BOT_INCOMING_TRADE_QUEUE_NAME=incoming-trades
BOT_TRADE_STATUS_QUEUE_NAME=trade-status
AZURE_QUEUE_CONNECTION_STRING=
AZURE_QUEUE_ACCOUNT_NAME=
BOT_QUEUE_CREATE_IF_NOT_EXISTS=false
BOT_QUEUE_VISIBILITY_TIMEOUT_SECONDS=60
BOT_QUEUE_MAX_MESSAGES=1
BOT_QUEUE_MAX_DEQUEUE_COUNT=5
