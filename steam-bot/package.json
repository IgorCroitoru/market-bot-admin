{
  "name": "steam-bot",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "npm run build && node dist/index.js",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@azure/identity": "^4.13.1",
    "@azure/keyvault-secrets": "^4.11.1",
    "@azure/storage-blob": "^12.31.0",
    "@market-bot-admin/logging": "file:../packages/logging",
    "@market-bot-admin/queue": "file:../packages/queue",
    "@market-bot-admin/shared": "file:../packages/shared",
    "@market-bot-admin/config": "file:../packages/config",
    "dotenv": "^17.4.2",
    "jsonwebtoken": "^9.0.3",
    "steam-session": "^1.9.4",
    "steam-totp": "^2.1.2",
    "steam-tradeoffer-manager": "^2.13.0",
    "steamcommunity": "^3.50.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/steam-totp": "^2.1.2",
    "@types/steam-tradeoffer-manager": "^2.11.2",
    "@types/steamcommunity": "^3.43.8",
    "typescript": "^6.0.3"
  }
}
